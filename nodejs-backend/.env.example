# Application
NODE_ENV=development
PORT=3000

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=hospital_db
POSTGRES_USER=hospital_user
POSTGRES_PASSWORD=hospital_pass
DATABASE_URL=postgresql://hospital_user:hospital_pass@postgres:5432/hospital_db?schema=public

# Redis
REDIS_HOST=redis-nodejs
REDIS_PORT=6379

# Frappe/ERPNext
FRAPPE_URL=http://backend:8000
FRAPPE_API_KEY=your_api_key_here
FRAPPE_API_SECRET=your_api_secret_here
FRAPPE_SITE=frontend

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Webhook Security
WEBHOOK_SECRET=webhook-secret-change-this-in-production

# Twilio for SMS/WhatsApp
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_WHATSAPP_NUMBER=whatsapp:+1234567890

# Stripe/Razorpay (Optional)
STRIPE_SECRET_KEY=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# SMTP (Optional - for custom emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# File Upload
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=pdf,jpg,jpeg,png,doc,docx

# Cache TTL (seconds)
CACHE_TTL_DOCTORS=300
CACHE_TTL_DEPARTMENTS=600
CACHE_TTL_PATIENTS=300
CACHE_TTL_SLOTS=60

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info
