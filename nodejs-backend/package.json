{
  "name": "hospital-management-api",
  "version": "1.0.0",
  "description": "Hospital Management System - Node.js Backend with Frappe Integration",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
