generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User sessions (JWT alternative for web)
model UserSession {
  id           String   @id @default(uuid())
  userId       String
  frappeUserId String   @map("frappe_user_id")
  token        String   @unique
  refreshToken String   @unique @map("refresh_token")
  deviceInfo   String?  @map("device_info")
  ipAddress    String?  @map("ip_address")
  expiresAt    DateTime @map("expires_at")
  createdAt    DateTime @default(now()) @map("created_at")
  lastUsedAt   DateTime @default(now()) @map("last_used_at")

  @@index([userId])
  @@index([frappeUserId])
  @@map("user_sessions")
}

// SMS/WhatsApp Notification Logs
model NotificationLog {
  id             String    @id @default(uuid())
  type           String    // SMS, WHATSAPP, EMAIL
  recipient      String
  recipientType  String    @map("recipient_type") // PATIENT, DOCTOR
  recipientId    String    @map("recipient_id") // Frappe ID
  subject        String?
  message        String
  status         String    @default("PENDING") // PENDING, SENT, FAILED, DELIVERED
  provider       String?   // TWILIO, SNS, etc
  providerMsgId  String?   @map("provider_msg_id")
  error          String?
  metadata       Json?
  sentAt         DateTime? @map("sent_at")
  deliveredAt    DateTime? @map("delivered_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  @@index([recipientId])
  @@index([status])
  @@index([createdAt])
  @@map("notification_logs")
}

// Payment Transactions
model PaymentTransaction {
  id                 String    @id @default(uuid())
  patientId          String    @map("patient_id") // Frappe Patient ID
  appointmentId      String?   @map("appointment_id") // Frappe Appointment ID
  amount             Decimal   @db.Decimal(10, 2)
  currency           String    @default("INR")
  status             String    @default("PENDING") // PENDING, SUCCESS, FAILED, REFUNDED
  paymentMethod      String    @map("payment_method") // CARD, UPI, WALLET, CASH
  paymentGateway     String?   @map("payment_gateway") // STRIPE, RAZORPAY
  gatewayTxnId       String?   @unique @map("gateway_txn_id")
  gatewayResponse    Json?     @map("gateway_response")
  refundId           String?   @map("refund_id")
  refundAmount       Decimal?  @map("refund_amount") @db.Decimal(10, 2)
  refundedAt         DateTime? @map("refunded_at")
  metadata           Json?
  paidAt             DateTime? @map("paid_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  @@index([patientId])
  @@index([appointmentId])
  @@index([status])
  @@map("payment_transactions")
}

// Appointment Queue (for clinic display)
model AppointmentQueue {
  id              String    @id @default(uuid())
  appointmentId   String    @unique @map("appointment_id") // Frappe Appointment ID
  patientId       String    @map("patient_id")
  patientName     String    @map("patient_name")
  doctorId        String    @map("doctor_id")
  doctorName      String    @map("doctor_name")
  tokenNumber     Int       @map("token_number")
  status          String    @default("WAITING") // WAITING, CALLED, IN_PROGRESS, COMPLETED, CANCELLED
  appointmentTime DateTime  @map("appointment_time")
  calledAt        DateTime? @map("called_at")
  completedAt     DateTime? @map("completed_at")
  estimatedTime   DateTime? @map("estimated_time")
  priority        Int       @default(0) // 0=normal, 1=priority, 2=emergency
  metadata        Json?
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@index([doctorId, status])
  @@index([appointmentTime])
  @@map("appointment_queue")
}

// Custom Reports/Documents Upload
model DocumentUpload {
  id            String   @id @default(uuid())
  patientId     String   @map("patient_id")
  appointmentId String?  @map("appointment_id")
  documentType  String   @map("document_type") // PRESCRIPTION, LAB_REPORT, XRAY, MRI, etc
  fileName      String   @map("file_name")
  filePath      String   @map("file_path")
  fileSize      Int      @map("file_size")
  mimeType      String   @map("mime_type")
  uploadedBy    String   @map("uploaded_by") // User ID
  uploadedByType String  @map("uploaded_by_type") // PATIENT, DOCTOR, ADMIN
  metadata      Json?
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([patientId])
  @@index([appointmentId])
  @@map("document_uploads")
}

// Audit/Activity Logs
model AuditLog {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  userType   String   @map("user_type") // PATIENT, DOCTOR, ADMIN
  action     String   // CREATE, UPDATE, DELETE, VIEW
  resource   String   // APPOINTMENT, PATIENT, PRESCRIPTION
  resourceId String   @map("resource_id")
  details    Json?
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([resource, resourceId])
  @@index([createdAt])
  @@map("audit_logs")
}

// Sync Status Tracking (for Frappe sync monitoring)
model SyncStatus {
  id            String    @id @default(uuid())
  entityType    String    @map("entity_type") // PATIENT, APPOINTMENT, PRESCRIPTION
  entityId      String    @map("entity_id") // ID in Node.js or Frappe
  syncDirection String    @map("sync_direction") // TO_FRAPPE, FROM_FRAPPE
  status        String    @default("PENDING") // PENDING, IN_PROGRESS, SUCCESS, FAILED
  attempts      Int       @default(0)
  lastAttemptAt DateTime? @map("last_attempt_at")
  error         String?
  payload       Json?
  syncedAt      DateTime? @map("synced_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@index([entityType, entityId])
  @@index([status])
  @@map("sync_status")
}

// Patient Cache (denormalized for quick access)
model PatientCache {
  id             String   @id // Frappe Patient ID
  firstName      String   @map("first_name")
  lastName       String?  @map("last_name")
  email          String   @unique
  mobile         String?
  dob            DateTime? @db.Date
  gender         String?
  bloodGroup     String?  @map("blood_group")
  address        String?
  city           String?
  country        String?
  emergencyContact String? @map("emergency_contact")
  lastVisit      DateTime? @map("last_visit")
  totalAppointments Int   @default(0) @map("total_appointments")
  metadata       Json?
  updatedAt      DateTime @updatedAt @map("updated_at")
  cacheExpiresAt DateTime @map("cache_expires_at")

  @@index([email])
  @@index([mobile])
  @@map("patient_cache")
}

// Doctor Cache (denormalized)
model DoctorCache {
  id             String   @id // Frappe Healthcare Practitioner ID
  firstName      String   @map("first_name")
  lastName       String?  @map("last_name")
  department     String?
  qualification  String?
  specialization String?
  email          String?
  mobile         String?
  consultationFee Decimal? @map("consultation_fee") @db.Decimal(10, 2)
  status         String   @default("Active")
  availableSlots Int      @default(0) @map("available_slots")
  metadata       Json?
  updatedAt      DateTime @updatedAt @map("updated_at")
  cacheExpiresAt DateTime @map("cache_expires_at")

  @@map("doctor_cache")
}

// User accounts for patient portal
model User {
  id              String    @id @default(uuid())
  email           String    @unique
  password        String
  firstName       String    @map("first_name")
  lastName        String?   @map("last_name")
  phone           String?
  role            String    @default("patient") // patient, admin
  frappePatientId String?   @unique @map("frappe_patient_id")
  dateOfBirth     DateTime? @map("date_of_birth")
  gender          String?
  bloodGroup      String?   @map("blood_group")
  address         String?
  isActive        Boolean   @default(true) @map("is_active")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  appointments Appointment[]

  @@index([email])
  @@index([frappePatientId])
  @@map("users")
}

// Local appointment records (synced with Frappe)
model Appointment {
  id                   String    @id @default(uuid())
  userId               String    @map("user_id")
  frappeAppointmentId  String?   @unique @map("frappe_appointment_id")
  practitioner         String
  appointmentDate      DateTime  @map("appointment_date")
  appointmentTime      String    @map("appointment_time")
  department           String?
  status               String    @default("Open")
  notes                String?
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([frappeAppointmentId])
  @@index([appointmentDate])
  @@map("appointments")
}
